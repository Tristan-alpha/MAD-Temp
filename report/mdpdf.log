   DEBUG: 2026-04-04 18:45:29,945:      pdf_renderer.py:  235: /export/home3/dazhou/debate-or-vote/report/../out/tg_mad_hh_rlhf_qwen25_7b_peragent_r2_bs1_ep3_nh100_20260325_try2/overall_accuracy_bar.png, 1200, 750
